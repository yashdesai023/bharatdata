.npm
.yarn-integrity
*.tsbuildinfo

# Debug / Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/

# Testing & Reports
coverage/
.nyc_output/
junit.xml
quality_report*.json
spot_check*.txt
