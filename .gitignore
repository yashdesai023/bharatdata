!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Data & Ingestion (Local Only)
data/
sources/
bharatdata-raw/
canonical-mappings/
temp_downloads/
*.db
*.sqlite
*.csv
*.xlsx
